# Optional: override where Tokometer scans Codex logs.
# TOKEN_GAUGE_CODEX_HOME=C:\Users\you\.codex

# Optional: override where Tokometer stores history snapshots.
# TOKEN_GAUGE_DATA_DIR=C:\Users\you\AppData\Roaming\Token Gauge

# Optional: production server port for npm run serve.
# PORT=4173

# Optional: make the Electron shell open an existing dev/prod server.
# TOKEN_GAUGE_URL=http://127.0.0.1:5173/
