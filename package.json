{
  "name": "tokometer",
  "private": false,
  "version": "0.1.0",
  "description": "A real local usage gauge for Codex token burn, rate limits, history, alerts, and exports.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Martin123132 <Martin123132@users.noreply.github.com>",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build && npm run build:server",
    "build:server": "node scripts/build-server.mjs",
    "icons:generate": "node scripts/generate-icon.mjs",
    "smoke": "npx tsx scripts/smoke-checks.mjs",
    "release:verify": "node scripts/verify-release.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "start": "npm run build && tsx server/standalone.ts",
    "serve": "tsx server/standalone.ts",
    "desktop": "node scripts/desktop.mjs",
    "desktop:prod": "npm run build && electron electron/main.cjs",
    "preview": "vite preview",
    "pack": "npm run icons:generate && npm run build && electron-builder --dir",
    "dist": "npm run icons:generate && npm run build && electron-builder --publish never"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Martin123132/Tokometer-a-real-usage-gauge-for-Codex-OpenAI-token-burn.git"
  },
  "homepage": "https://github.com/Martin123132/Tokometer-a-real-usage-gauge-for-Codex-OpenAI-token-burn",
  "bugs": {
    "url": "https://github.com/Martin123132/Tokometer-a-real-usage-gauge-for-Codex-OpenAI-token-burn/issues"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "dev.tokometer.app",
    "productName": "Tokometer",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json",
      "README.md",
      "LICENSE",
      "NOTICE.md",
      "COMMERCIAL-LICENSE.md"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Martin123132 <Martin123132@users.noreply.github.com>",
      "category": "Development"
    }
  }
}
